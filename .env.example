# Backend
DATABASE_URL=postgresql://user:password@localhost:5432/elon_bets

# Frontend (CRA)
# WalletConnect v2 Project ID used by RainbowKit
REACT_APP_WALLETCONNECT_PROJECT_ID=

# Optional. If empty, CRA will use the `proxy` in package.json (dev) or same-origin (prod).
REACT_APP_API_BASE_URL=

# Alchemy webhook signature secret (only needed if you use /api/tips/webhook)
ALCHEMY_WEBHOOK_SECRET=

# --- Market data sync (Gamma API) ---
# Public Gamma API base (no auth needed)
GAMMA_API_BASE=https://gamma-api.polymarket.com

# Optional filter (case-insensitive substring match on market question/slug)
# Example: MARKET_QUERY=elon
MARKET_QUERY=

# Max markets per sync batch (small to keep it cheap)
MARKET_LIMIT=50

# Scheduler toggle (APScheduler inside API server)
SCHEDULER_ENABLED=true

# Market sync interval (seconds)
MARKET_SYNC_INTERVAL_SECONDS=300
